# LUMEN v3 — environment variables
# Copy to .env and fill in your own keys. .env is gitignored.

# --- LLM provider keys (at least one required) ---
# OpenRouter unified gateway (recommended — used by configs/models.yaml)
OPENROUTER_API_KEY=

# Direct provider keys (optional, used as fallback or for specific tiers)
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
OPENAI_API_KEY=

# --- Literature search / PDF retrieval ---
NCBI_API_KEY=
NCBI_EMAIL=you@example.com
CONTACT_EMAIL=you@example.com
SEMANTIC_SCHOLAR_API_KEY=
